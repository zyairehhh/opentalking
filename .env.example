# OpenTalking environment template.
# Copy to .env and fill in only the keys you need; everything else has sane
# defaults (see packages/opentalking/core/config.py).
#
# Variable naming conventions:
#   OPENTALKING_*  — first-party knobs (Settings model)
#   DASHSCOPE_API_KEY  — third-party SDK env (used by some adapters directly)
#   OMNIRT_*       — external inference runtime (https://github.com/datascale-ai/omnirt)


# ============================================================================
# Service
# ============================================================================
OPENTALKING_LOG_LEVEL=INFO
OPENTALKING_CONFIG_FILE=./configs/default.yaml
SERVER_HOST=localhost

# Hardware profile (auto-detected by scripts/install.sh; set explicitly to override)
# values: cuda-4090 | cuda-3090 | ascend-910b | cpu-demo
OPENTALKING_HARDWARE_PROFILE=cuda-4090

# Process bind addresses
OPENTALKING_API_HOST=0.0.0.0
OPENTALKING_API_PORT=8000
OPENTALKING_UNIFIED_HOST=0.0.0.0
OPENTALKING_UNIFIED_PORT=8000
OPENTALKING_WORKER_HOST=0.0.0.0
OPENTALKING_WORKER_PORT=9001

# CORS allow-list for the web console (comma-separated, or "*" for any)
OPENTALKING_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


# ============================================================================
# Storage / infra
# ============================================================================
OPENTALKING_REDIS_URL=redis://localhost:6379/0
# OPENTALKING_REDIS_MODE=redis           # redis | memory (memory = single-process unified mode)

OPENTALKING_AVATARS_DIR=./examples/avatars
OPENTALKING_MODELS_DIR=./models
OPENTALKING_WORKER_URL=http://127.0.0.1:9001

# Voice clone catalog (SQLite)
# OPENTALKING_SQLITE_PATH=./data/opentalking.sqlite3

# Public base URL announced to TTS providers that need to fetch user uploads
# (e.g. CosyVoice voice-clone audio). Leave blank for localhost dev.
# OPENTALKING_PUBLIC_BASE_URL=


# ============================================================================
# Default avatar/runtime preferences
# ============================================================================
OPENTALKING_TORCH_DEVICE=cpu
OPENTALKING_DEFAULT_MODEL=flashtalk    # flashtalk | musetalk | wav2lip | flashhead
OPENTALKING_DEFAULT_FPS=25


# ============================================================================
# Inference service (omnirt)
# https://github.com/datascale-ai/omnirt
# All synthesis (FlashTalk / MuseTalk / Wav2Lip) is delegated to omnirt.
# ============================================================================
OMNIRT_ENDPOINT=http://omnirt:9000
OMNIRT_API_KEY=
OMNIRT_DEFAULT_BACKEND=cuda            # cuda | ascend | cpu


# ============================================================================
# FlashTalk synthesis (renderer params; passed to the omnirt FlashTalk endpoint)
# ============================================================================
OPENTALKING_FLASHTALK_WS_URL=ws://localhost:8765
OPENTALKING_FLASHTALK_CKPT_DIR=./models/SoulX-FlashTalk-14B
OPENTALKING_FLASHTALK_WAV2VEC_DIR=./models/chinese-wav2vec2-base
OPENTALKING_FLASHTALK_PORT=8765
OPENTALKING_FLASHTALK_DEVICE=auto
OPENTALKING_FLASHTALK_GPU_COUNT=8

# Frame / sampling
OPENTALKING_FLASHTALK_FRAME_NUM=25
OPENTALKING_FLASHTALK_MOTION_FRAMES_NUM=5
OPENTALKING_FLASHTALK_SAMPLE_STEPS=2
OPENTALKING_FLASHTALK_SAMPLE_SHIFT=5
OPENTALKING_FLASHTALK_HEIGHT=704
OPENTALKING_FLASHTALK_WIDTH=416
OPENTALKING_FLASHTALK_SAMPLE_RATE=16000
OPENTALKING_FLASHTALK_TGT_FPS=25
OPENTALKING_FLASHTALK_CACHED_AUDIO_DURATION=8
OPENTALKING_FLASHTALK_COLOR_CORRECTION_STRENGTH=0
OPENTALKING_FLASHTALK_AUDIO_LOUDNESS_NORM=0

# JPEG transport (worker → API)
OPENTALKING_FLASHTALK_JPEG_QUALITY=55
OPENTALKING_FLASHTALK_JPEG_WORKERS=4
OPENTALKING_FLASHTALK_JPEG_DECODE_WORKERS=4

# Idle clip generation
OPENTALKING_FLASHTALK_IDLE_ENABLE=1
OPENTALKING_FLASHTALK_IDLE_SOURCE=generated   # generated | video
OPENTALKING_FLASHTALK_IDLE_CACHE_CHUNKS=4
OPENTALKING_FLASHTALK_IDLE_CACHE_DIR=./models/.idle_cache
OPENTALKING_FLASHTALK_IDLE_EXPORT_ENABLE=1
OPENTALKING_FLASHTALK_IDLE_EXPORT_DIR=./data/session_recordings/idle
OPENTALKING_FLASHTALK_IDLE_MOUTH_LOCK=0.97
OPENTALKING_FLASHTALK_IDLE_EYE_LOCK=0.65
OPENTALKING_FLASHTALK_IDLE_SEED=9999
# OPENTALKING_FLASHTALK_IDLE_PROMPT=

# TTS coalescing / fade for clean splice points
OPENTALKING_FLASHTALK_PREBUFFER_CHUNKS=2
OPENTALKING_FLASHTALK_TTS_BOUNDARY_FADE_MS=18
OPENTALKING_FLASHTALK_TTS_COALESCE_MIN_CHARS=6
OPENTALKING_FLASHTALK_TTS_COALESCE_MAX_CHARS=80
OPENTALKING_FLASHTALK_TTS_TAIL_FADE_MS=80
OPENTALKING_FLASHTALK_TTS_TRAILING_SILENCE_MS=320

# TTS opener trick (play canned phrase while LLM thinks); off by default
OPENTALKING_FLASHTALK_TTS_OPENER_ENABLE=0
OPENTALKING_FLASHTALK_TTS_OPENER_PRELOAD=0
OPENTALKING_FLASHTALK_TTS_OPENER_MIN_FILL_RATIO=0.78
OPENTALKING_FLASHTALK_TTS_OPENER_PAD_TO_CHUNK=1
OPENTALKING_FLASHTALK_TTS_OPENER_MAX_HISTORY=2
OPENTALKING_FLASHTALK_PROGRESSIVE_SEND=0


# ============================================================================
# FlashHead synthesis (alternative high-quality path)
# ============================================================================
# OPENTALKING_FLASHHEAD_WS_URL=ws://localhost:8766/v1/avatar/realtime
# OPENTALKING_FLASHHEAD_BASE_URL=http://localhost:8766
# OPENTALKING_FLASHHEAD_MODEL=soulx-flashhead-1.3b
# OPENTALKING_FLASHHEAD_SHARED_LOCAL_DIR=/tmp/opentalking_flashhead_io
# OPENTALKING_FLASHHEAD_SHARED_REMOTE_DIR=/tmp/opentalking_flashhead_io
# OPENTALKING_FLASHHEAD_TIMEOUT_SEC=600


# ============================================================================
# LLM (OpenAI-compatible — works with Qwen, vLLM, etc.)
# ============================================================================
OPENTALKING_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENTALKING_LLM_API_KEY=
OPENTALKING_LLM_MODEL=qwen-turbo
OPENTALKING_LLM_SYSTEM_PROMPT=你是一个友好的数字人助手，请用简洁的口语化语言回答问题。不要使用 markdown 格式、列表、加粗、标题等排版符号，不要使用表情符号或 emoji。用自然的对话方式回答即可。


# ============================================================================
# STT (DashScope Paraformer realtime; key shared with LLM if same account)
# ============================================================================
# DASHSCOPE_API_KEY can be omitted if OPENTALKING_LLM_API_KEY is the same DashScope key.
DASHSCOPE_API_KEY=
OPENTALKING_STT_MODEL=paraformer-realtime-v2
# OPENTALKING_STT_LANGUAGE_HINTS=zh,en


# ============================================================================
# TTS — provider selection
#   edge              (default; offline, no key)
#   dashscope         (Qwen TTS realtime; uses DASHSCOPE_API_KEY)
#   cosyvoice         (DashScope CosyVoice WS; supports voice cloning)
#   sambert           (DashScope Sambert)
#   elevenlabs        (ElevenLabs cloud)
# ============================================================================
OPENTALKING_TTS_PROVIDER=edge
OPENTALKING_TTS_VOICE=zh-CN-XiaoxiaoNeural
OPENTALKING_TTS_SAMPLE_RATE=16000
OPENTALKING_TTS_STREAMING_DECODE=1
OPENTALKING_FFMPEG_BIN=ffmpeg

# Qwen TTS (when OPENTALKING_TTS_PROVIDER=dashscope)
OPENTALKING_QWEN_TTS_REUSE_WS=1
# OPENTALKING_QWEN_TTS_MODEL=qwen3-tts-flash-realtime
# OPENTALKING_QWEN_TTS_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
# OPENTALKING_QWEN_TTS_MODE=commit
# OPENTALKING_QWEN_TTS_LANGUAGE=Chinese

# ElevenLabs (when OPENTALKING_TTS_PROVIDER=elevenlabs)
# OPENTALKING_TTS_ELEVENLABS_API_KEY=
# OPENTALKING_TTS_ELEVENLABS_BASE_URL=https://api.elevenlabs.io
# OPENTALKING_TTS_ELEVENLABS_MODEL_ID=eleven_flash_v2_5
# OPENTALKING_TTS_ELEVENLABS_VOICE_ID=
# OPENTALKING_TTS_ELEVENLABS_OUTPUT_FORMAT=mp3_22050_32
