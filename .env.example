# =============================================================================
# OpenTalking 环境变量模板
#
# 配置策略：从上往下读，遇到自己用得上的小节就停。
#   ▸ 路径 1（快速体验）：只配第 1 节就够
#   ▸ 路径 2（轻量适配）：第 1 + 2 节
#   ▸ 路径 3（高质量部署）：第 1 + 2 + 3 节
#   ▸ 第 4 节是高级 / 微调，绝大多数用户不用动
#
# 命名约定：
#   OPENTALKING_*       本仓配置（Settings 模型字段）
#   OMNIRT_*            外部推理运行时 (https://github.com/datascale-ai/omnirt)
# =============================================================================


# =============================================================================
# 1. 必填：LLM / STT / TTS（README 路径 1 / 快速体验）
# 合成层是否走 Mock 由前端 model 下拉框决定（选 mock 即可），无需在这里配置。
#
# 重要规则：
#   1. LLM / STT / TTS 是三个独立模块，不共享 API Key。
#   2. *_DEFAULT_PROVIDER 只决定“默认选中哪个 provider”，不是失败 fallback。
#   3. 前端仍可按请求切换 provider；切到 API provider 时必须配置该 provider 的 key。
#   4. 旧的 DASHSCOPE_API_KEY、OPENTALKING_STT_API_KEY、OPENTALKING_TTS_API_KEY
#      不再自动作用于 STT/TTS。请使用下面的 provider-specific 变量。
#   5. 启动后可访问 /health 或 /api/runtime/status 查看最终生效配置。
# =============================================================================

# -----------------------------------------------------------------------------
# 1.1 LLM：文本大模型
# -----------------------------------------------------------------------------
# 支持任何 OpenAI-compatible endpoint（百炼 / DashScope / OpenAI / vLLM / Ollama）。
# 这里只影响 LLM，不会给 STT/TTS 自动提供 key。
OPENTALKING_LLM_PROVIDER=openai_compatible
OPENTALKING_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENTALKING_LLM_API_KEY=
OPENTALKING_LLM_MODEL=qwen-flash
OPENTALKING_LLM_SYSTEM_PROMPT=你是一个友好的数字人助手，请用简洁的口语化语言回答问题。不要使用 markdown 格式、列表、加粗、标题等排版符号，不要使用表情符号或 emoji。

# -----------------------------------------------------------------------------
# 1.2 STT：语音转文字默认路由
# -----------------------------------------------------------------------------
# 可选 provider：dashscope（API）/ sensevoice（本地）
# DEFAULT_PROVIDER 只是默认值；前端选择 API STT 时，会检查 OPENTALKING_STT_DASHSCOPE_API_KEY。
# ENABLED_PROVIDERS 控制前端/状态页可展示的候选，不表示 fallback 顺序。
OPENTALKING_STT_DEFAULT_PROVIDER=dashscope
OPENTALKING_STT_ENABLED_PROVIDERS=dashscope,sensevoice

# STT provider: DashScope API
# 适合不想本地部署 STT 的场景。Paraformer 走 DashScope SDK 内置 endpoint，
# 这里只需要模型名和 key；即使 LLM 也用 DashScope，也需要在这里显式填 key。
OPENTALKING_STT_DASHSCOPE_MODEL=paraformer-realtime-v2
OPENTALKING_STT_DASHSCOPE_API_KEY=

# STT provider: SenseVoice 本地模型
# 适合本地部署；CPU 通常够用。MODEL_DIR 指向下载后的模型目录，不要提交权重到 git。
OPENTALKING_STT_SENSEVOICE_MODEL=iic/SenseVoiceSmall
OPENTALKING_STT_SENSEVOICE_MODEL_DIR=./models/local-audio/iic__SenseVoiceSmall
OPENTALKING_STT_SENSEVOICE_DEVICE=cpu

# -----------------------------------------------------------------------------
# 1.3 TTS：文字转语音默认路由
# -----------------------------------------------------------------------------
# 可选 provider：edge（无需 key）/ dashscope（API）/ local_cosyvoice（本地）
# DEFAULT_PROVIDER 只是默认值；前端选择 API TTS 时，会检查 OPENTALKING_TTS_DASHSCOPE_API_KEY。
# ENABLED_PROVIDERS 控制前端/状态页可展示的候选，不表示 fallback 顺序。
OPENTALKING_TTS_DEFAULT_PROVIDER=edge
OPENTALKING_TTS_ENABLED_PROVIDERS=edge,dashscope,local_cosyvoice

# TTS provider: Edge
# 无需 key，依赖网络访问 Microsoft Edge TTS。
OPENTALKING_TTS_EDGE_VOICE=zh-CN-XiaoxiaoNeural

# TTS provider: DashScope Qwen-TTS API
# 适合不想本地部署 TTS 的场景。即使 LLM 也用 DashScope，也需要在这里显式填 key。
OPENTALKING_TTS_DASHSCOPE_MODEL=qwen3-tts-flash-realtime
OPENTALKING_TTS_DASHSCOPE_VOICE=Cherry
OPENTALKING_TTS_DASHSCOPE_API_KEY=
OPENTALKING_TTS_DASHSCOPE_SERVICE_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime

# TTS provider: Local CosyVoice
# SERVICE_URL 为空时尝试进程内加载；生产/绿色包建议独立启动本地 CosyVoice service。
# MODEL_DIR / RUNTIME_DIR 指向本地权重和运行时代码目录，不要提交权重到 git。
OPENTALKING_TTS_LOCAL_COSYVOICE_MODEL=FunAudioLLM/Fun-CosyVoice3-0.5B-2512
OPENTALKING_TTS_LOCAL_COSYVOICE_MODEL_DIR=./models/local-audio/FunAudioLLM__Fun-CosyVoice3-0.5B-2512
OPENTALKING_TTS_LOCAL_COSYVOICE_RUNTIME_DIR=./models/local-audio/runtime/CosyVoice
OPENTALKING_TTS_LOCAL_COSYVOICE_SERVICE_URL=http://127.0.0.1:19090/synthesize
OPENTALKING_TTS_LOCAL_COSYVOICE_DEVICE=cuda:0

# =============================================================================
# 2. 推理服务接入（README 路径 2 / 轻量适配验证）
# 配下面这一组后，前端选 flashtalk / musetalk / wav2lip 才能跑真实推理；
# 选 mock 始终可用，无需任何推理服务配置。
# =============================================================================

# --- 推荐：OmniRT 统一 endpoint（一个变量服务多个模型）---
# 启用后 flashtalk / musetalk / wav2lip 都走它；按路径路由到对应模型：
#   ws://<host>:9000/v1/audio2video/{model}
# 本地起一个：bash scripts/run_omnirt.sh
# OMNIRT_ENDPOINT=http://localhost:9000
# OMNIRT_API_KEY=
# 仅当你的 OmniRT URL 路径不一样时才覆盖（默认就够了）：
# OPENTALKING_OMNIRT_AUDIO2VIDEO_PATH_TEMPLATE=/v1/audio2video/{model}

# 注：合成模型（mock / wav2lip / musetalk / flashtalk / flashhead）由前端
# 每次创建会话时显式指定，不在这里默认。mock / wav2lip local 不需要
# OmniRT；musetalk / flashtalk 可通过 OMNIRT_ENDPOINT 统一连接可用模型。

# --- 兼容：直连单模型 WS（OMNIRT_ENDPOINT 没设时才生效）---
# 仅在没有 OmniRT、直接对接 SoulX FlashTalk 单进程时使用。
# OPENTALKING_FLASHTALK_WS_URL=ws://<host>:8765

# --- FlashHead（独立 WS 协议，与 OmniRT 不互通，目前仍单独配置）---
# OPENTALKING_FLASHHEAD_WS_URL=ws://<host>:8766/v1/avatar/realtime
# OPENTALKING_FLASHHEAD_BASE_URL=http://<host>:8766
# OPENTALKING_FLASHHEAD_MODEL=soulx-flashhead-1.3b


# =============================================================================
# 3. 多进程 / 生产部署（README 路径 3 / 高质量部署）
# 单进程开发模式（opentalking-unified）不需要这一节。
# =============================================================================

# Redis（多进程必须；单进程模式可设 OPENTALKING_REDIS_MODE=memory）
# OPENTALKING_REDIS_URL=redis://localhost:6379/0
# OPENTALKING_REDIS_MODE=redis

# 进程绑定地址 / 端口
# OPENTALKING_API_HOST=0.0.0.0
# OPENTALKING_API_PORT=8000
# OPENTALKING_WORKER_HOST=0.0.0.0
# OPENTALKING_WORKER_PORT=9001
# OPENTALKING_WORKER_URL=http://127.0.0.1:9001

# 编排层硬件（音频 PCM 处理 / 帧后处理）
# OPENTALKING_TORCH_DEVICE=cuda

# 资产目录
# OPENTALKING_AVATARS_DIR=./examples/avatars
# OPENTALKING_VOICES_DIR=./var/voices
# OPENTALKING_SQLITE_PATH=./data/opentalking.sqlite3

# 前端 CORS 白名单（多前端域名时必填）
# OPENTALKING_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


# =============================================================================
# 4. 进阶 / 微调（按需开启；99% 的用户不用动）
# =============================================================================

# ---- 日志 / 服务标识 ----
# OPENTALKING_LOG_LEVEL=INFO
# OPENTALKING_CONFIG_FILE=./configs/default.yaml
# SERVER_HOST=localhost
# OPENTALKING_PUBLIC_BASE_URL=        # 给 CosyVoice 等需要公网 URL 拉音频的服务用

# ---- TTS 切换为百炼 Qwen 实时 TTS（需显式配置 TTS provider key）----
# OPENTALKING_TTS_DEFAULT_PROVIDER=dashscope
# OPENTALKING_TTS_DASHSCOPE_MODEL=qwen3-tts-flash-realtime
# OPENTALKING_TTS_DASHSCOPE_VOICE=Cherry
# OPENTALKING_TTS_DASHSCOPE_API_KEY=
# OPENTALKING_TTS_DASHSCOPE_SERVICE_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
# OPENTALKING_QWEN_TTS_REUSE_WS=1
# OPENTALKING_QWEN_TTS_LANGUAGE=Chinese

# ---- TTS 切换为 ElevenLabs ----
# 仍使用 ElevenLabs 自己的 provider key，不读取 DashScope / LLM key。
# OPENTALKING_TTS_DEFAULT_PROVIDER=elevenlabs
# OPENTALKING_TTS_ELEVENLABS_API_KEY=
# OPENTALKING_TTS_ELEVENLABS_VOICE_ID=
# OPENTALKING_TTS_ELEVENLABS_MODEL_ID=eleven_flash_v2_5
# OPENTALKING_TTS_ELEVENLABS_OUTPUT_FORMAT=mp3_22050_32

# ---- FlashTalk 渲染微调（仅当 DEFAULT_MODEL=flashtalk 才生效）----
# OPENTALKING_FLASHTALK_FRAME_NUM=25
# OPENTALKING_FLASHTALK_MOTION_FRAMES_NUM=5
# OPENTALKING_FLASHTALK_SAMPLE_STEPS=2
# OPENTALKING_FLASHTALK_HEIGHT=704
# OPENTALKING_FLASHTALK_WIDTH=416
# OPENTALKING_FLASHTALK_TGT_FPS=25
# OPENTALKING_FLASHTALK_JPEG_QUALITY=55

# ---- FlashTalk idle 帧（说话间隙）----
# OPENTALKING_FLASHTALK_IDLE_ENABLE=1
# OPENTALKING_FLASHTALK_IDLE_SOURCE=generated   # generated | video
# OPENTALKING_FLASHTALK_IDLE_CACHE_DIR=./models/.idle_cache
# OPENTALKING_FLASHTALK_IDLE_MOUTH_LOCK=0.97
# OPENTALKING_FLASHTALK_IDLE_EYE_LOCK=0.65

# ---- FlashTalk TTS 拼接平滑 ----
# OPENTALKING_FLASHTALK_TTS_BOUNDARY_FADE_MS=18
# OPENTALKING_FLASHTALK_TTS_COALESCE_MIN_CHARS=6
# OPENTALKING_FLASHTALK_TTS_COALESCE_MAX_CHARS=80
# OPENTALKING_FLASHTALK_TTS_TAIL_FADE_MS=80
# OPENTALKING_FLASHTALK_TTS_TRAILING_SILENCE_MS=320

# ---- FlashHead（独立 WebSocket 协议，不经 OmniRT）----
# OPENTALKING_FLASHHEAD_WS_URL=ws://localhost:8766/v1/avatar/realtime
# OPENTALKING_FLASHHEAD_BASE_URL=http://localhost:8766
# OPENTALKING_FLASHHEAD_MODEL=soulx-flashhead-1.3b
# OPENTALKING_FLASHHEAD_TIMEOUT_SEC=600

# ---- Wav2Lip（本地口型同步，可选）----
# 使用时选择 model=wav2lip；不需要启动独立推理服务。
# OPENTALKING_WAV2LIP_MODEL_ROOT=/path/to/opentalking/models/wav2lip
# OPENTALKING_WAV2LIP_DEVICE=cuda
# OPENTALKING_WAV2LIP_BATCH_SIZE=4
# OPENTALKING_WAV2LIP_MAX_LONG_EDGE=768

# ---- QuickTalk（本地实时 talking-head，可选）----
# 使用时选择 model=quicktalk，并确保 avatar manifest 的 model_type=quicktalk。
# OPENTALKING_TORCH_DEVICE=cuda:0
# OPENTALKING_QUICKTALK_ASSET_ROOT=/path/to/quicktalk/assets
# OPENTALKING_QUICKTALK_MODEL_BACKEND=auto   # auto 优先 quicktalk.pth；可设为 onnx 或 pth
# OPENTALKING_QUICKTALK_TEMPLATE_VIDEO=/path/to/template.mp4
# OPENTALKING_QUICKTALK_FACE_CACHE_DIR=/path/to/.face_cache_quicktalk
# OPENTALKING_QUICKTALK_HUBERT_DEVICE=       # 留空表示与 OPENTALKING_TORCH_DEVICE 同卡
# OPENTALKING_QUICKTALK_WORKER_CACHE=1       # 复用同 Avatar Worker，降低后续会话启动成本
# OPENTALKING_PREWARM_AVATARS=               # 例如 quicktalk-daytime，启动时提前构建 Worker
# OPENTALKING_QUICKTALK_RENDER_CHUNK_MS=500
# OPENTALKING_QUICKTALK_PREFETCH=1
# OPENTALKING_QUICKTALK_AUDIO_DELAY_MS=0
# OPENTALKING_QUICKTALK_IDLE_CACHE_FRAMES=1
# OPENTALKING_QUICKTALK_IDLE_FRAME_INDEX=0
# OPENTALKING_QUICKTALK_IDLE_FRAME_RANGE=

# ---- Legacy / ignored vendor env ----
# 以下旧变量不会自动配置 LLM/STT/TTS，保留为空可避免误判。
# DASHSCOPE_API_KEY=
# OPENTALKING_STT_PROVIDER=
# OPENTALKING_STT_MODEL=
# OPENTALKING_STT_API_KEY=
# OPENTALKING_TTS_PROVIDER=
# OPENTALKING_TTS_MODEL=
# OPENTALKING_TTS_API_KEY=

# ---- 其它 ----
# OPENTALKING_DEFAULT_FPS=25
# OPENTALKING_FFMPEG_BIN=ffmpeg
# OPENTALKING_TTS_SAMPLE_RATE=16000
# OPENTALKING_TTS_STREAMING_DECODE=1
